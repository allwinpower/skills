# Required: must match top-level Compose `name: ${PROJECT}`.
PROJECT=private-service-access

# Optional for deploy-tool remote mode.
# SSH_URI=ssh://admin@example.com

# Port the service listens on inside the container.
SERVICE_PORT=3000

# Remote host loopback-only port. Check the remote host first with: ssh user@host 'ss -ltn'
REMOTE_ACCESS_PORT=18080

# Local developer-machine port for the SSH tunnel. Check locally first with: ss -ltn
LOCAL_TUNNEL_PORT=8080
