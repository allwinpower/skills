# Required: must match top-level Compose `name: ${PROJECT}`.
PROJECT=my-service

# Optional: set for remote Docker deployment. Direct actions require --local or --remote when this is set.
# SSH_URI=ssh://admin@example.com

NODE_ENV=production
APP_HOST=0.0.0.0
APP_PORT=3000
APP_BIND_ADDR=127.0.0.1
APP_BASE_URL=https://example.com

# External Docker network name. The deploy tool can create declared external networks from its menu.
PUBLIC_NETWORK=cloudflare-net

# Local path, relative to docker-compose.yml unless absolute. Keep the real file out of git.
APP_SECRET_FILE_HOST=./secrets/app-secret.txt
